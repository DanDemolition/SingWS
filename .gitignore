# Local/editor clutter
.DS_Store
.cache/
.pytest_cache/
__pycache__/
*.pyc

# Local environment and secrets
.env
venv/
.venv/
.venv-universal/

# Build outputs and packaged artifacts
build/
dist/
*.app
*.dmg
*.pkg
*.zip
*.log

# Large local media/tooling artifacts
bin/
bin/ffmpeg*
bin/ffprobe*
gstreamer-sdk/
gstreamer-1.0-*.pkg
openkj.sqlite

# Backups
*.bak
*.bak*
*.icns.bak*
*.iconset.bak*/

# Current PyInstaller specs are source for the active release builders.
# Stable (version-agnostic) names so the version lives only in APP_VERSION.
*.spec
!SingWS-universal.spec
!SingWS-x86_64.spec
!SingWS-arm64.spec
